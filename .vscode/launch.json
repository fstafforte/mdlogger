    "version": "0.2.0",
    "configurations": [

        {
            "name": "Debug unit tests in library 'mdlogger'",
            "type": "lldb",
            "request": "launch",
            "cargo": {
                "args": [
                    "test"
                ]
            }
        },
        {
            "name": "Debug executable 'mdlogger_test_helper'",
            "type": "lldb",
            "request": "launch",
            "cargo": {
                "args": [
                    "run",
                    "--bin=mdlogger_test_helper"
                ]
            },
            "args": ["-t", "udp", "-a", "::1", "-p", "8000"]
        },
        {
            "name": "Debug unit tests in executable 'mdlogger_test_helper'",
            "type": "lldb",
            "request": "launch",
            "cargo": {
                "args": [
                    "test",
                    "--bin=mdlogger_test_helper"
                ]
            }
        }
    ]
}